NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role Supabase client (server-side only; never expose to browser).
# Used by /api/v1/* and /api/mcp after API-key auth has validated the request.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Daily-rotated salt for hashing anonymous landing-page visitors (page tracker).
# Generate with: openssl rand -hex 32
TRACK_DAILY_SALT=replace-me-with-32-random-bytes

# ---------------------------------------------------------------------------
# Stripe — pricing (already in production env; mirror locally for testing).
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_BASIC_MONTHLY_PRICE_ID=
STRIPE_BASIC_ANNUAL_PRICE_ID=

# ---------------------------------------------------------------------------
# Hosted MCP / REST API (fundingscout.io/mcp, /api/v1/*) — added 2026-05-11.
# ---------------------------------------------------------------------------

# Kill switch. Set to "false" to disable the MCP route (returns 503) without
# a redeploy. REST endpoints under /api/v1/* keep working — flip those off
# manually if you need to take the whole API down.
MCP_ENABLED=true
